rules_version = '2';

// All Firestore access goes through Cloud Functions (Admin SDK), which bypasses
// these rules entirely. Direct client access to every document is denied.
//
// TTL POLICY (set via gcloud CLI):
//   gcloud firestore fields ttls update expiresAt --collection-group=ai_usage_events \
//     --enable-ttl --project=iicocece-assessment
// This auto-deletes ai_usage_events documents 90 days after their expiresAt timestamp.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
